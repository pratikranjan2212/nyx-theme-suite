{
  "name": "True Dark",
  "type": "dark",
  "colors": {
    "focusBorder": "#8B5CF6",
    "foreground": "#dfdfe0",
    "widget.border": "#1E1E1E",
    "editor.background": "#121212",
    "editor.foreground": "#dfdfe0",
    "editorCursor.foreground": "#dfdfe0",
    "editor.lineHighlightBackground": "#1C1C1C",
    "editor.lineHighlightBorder": "#ffffff00",
    "editor.selectionBackground": "#2a3a5c",
    "editor.inactiveSelectionBackground": "#ffffff11",
    "editorLineNumber.foreground": "#5a6577",
    "editorLineNumber.activeForeground": "#8B5CF6",
    "sideBar.background": "#121212",
    "sideBar.foreground": "#dfdfe0",
    "sideBar.border": "#1E1E1E",
    "sideBarTitle.foreground": "#dfdfe0",
    "sideBarSectionHeader.background": "#121212",
    "sideBarSectionHeader.foreground": "#dfdfe0",
    "sideBarSectionHeader.border": "#1E1E1E",
    "activityBar.background": "#121212",
    "activityBar.foreground": "#ffffff",
    "activityBar.inactiveForeground": "#ffffff66",
    "activityBar.border": "#1E1E1E",
    "activityBarBadge.background": "#8B5CF6",
    "activityBarBadge.foreground": "#ffffff",
    "titleBar.activeBackground": "#121212",
    "titleBar.activeForeground": "#dfdfe0",
    "titleBar.inactiveBackground": "#121212",
    "titleBar.border": "#1E1E1E",
    "statusBar.background": "#121212",
    "statusBar.foreground": "#dfdfe0",
    "statusBar.border": "#1E1E1E",
    "editorGroupHeader.tabsBackground": "#121212",
    "editorGroupHeader.tabsBorder": "#1E1E1E",
    "tab.activeBackground": "#121212",
    "tab.activeForeground": "#ffffff",
    "tab.activeBorder": "#8B5CF6",
    "tab.inactiveBackground": "#121212",
    "tab.inactiveForeground": "#ffffff66",
    "tab.border": "#1E1E1E",
    "list.hoverBackground": "#1F1F1F",
    "list.activeSelectionBackground": "#2D2D2D",
    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#1F1F1F",
    "list.inactiveSelectionForeground": "#dfdfe0",
    "panel.background": "#121212",
    "panel.border": "#1E1E1E",
    "panelTitle.activeForeground": "#8B5CF6",
    "panelTitle.inactiveForeground": "#ffffff66",
    "button.background": "#8B5CF6",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#9d76fd",
    "input.background": "#121212",
    "input.foreground": "#dfdfe0",
    "input.border": "#1E1E1E",
    "menu.background": "#121212",
    "menu.foreground": "#dfdfe0",
    "menu.separatorBackground": "#1E1E1E",
    "scrollbarSlider.background": "#ffffff11",
    "scrollbarSlider.hoverBackground": "#ffffff22",
    "scrollbarSlider.activeBackground": "#8B5CF680"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "unused.comment"
      ],
      "settings": {
        "foreground": "#7f8c98",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#ff7ab2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#ff8170"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#d9c97c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b281eb",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String Escapes",
      "scope": [
        "constant.character.escape",
        "constant.escape"
      ],
      "settings": {
        "foreground": "#acf2e4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function Declarations",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#5ac8db",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#78c2b3"
      }
    },
    {
      "name": "Class Names",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#6bdfff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interface Names",
      "scope": [
        "entity.name.type.interface",
        "support.type"
      ],
      "settings": {
        "foreground": "#dabaff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#78c2b3"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#78c2b3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties / Fields",
      "scope": [
        "variable.other.property",
        "support.type.property-name",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#5ac8db"
      }
    },
    {
      "name": "Annotations / Attributes",
      "scope": [
        "meta.annotation",
        "entity.name.type.annotation",
        "entity.other.attribute-name",
        "meta.decorator"
      ],
      "settings": {
        "foreground": "#dabaff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML/XML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff7ab2",
        "fontStyle": "bold"
      }
    }
  ]
}